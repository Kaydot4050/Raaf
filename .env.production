# Production build (GitHub Actions). Secrets override these at deploy time.
VITE_API_URL=https://api.raafortagro.com/api
VITE_ADMIN_URL=https://admin.raafortagro.com
# VITE_GOOGLE_CLIENT_ID — set GitHub secret (same value as API GOOGLE_CLIENT_ID)
# VITE_SITE_PUBLIC=true — set GitHub secret when launching (unlocks site vs Coming Soon)
