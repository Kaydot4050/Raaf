# Dev: leave unset to use Vite proxy (/api). Production build (GitHub / CI):
# Use the URL that actually serves Node — often the MAIN site, not api.* unless that subdomain exists.
# VITE_API_URL=http://localhost:3001/api
# VITE_API_URL=https://raafortagro.com/api
# Only if api.raafortagro.com is configured in DNS + cPanel Node app:
# VITE_API_URL=https://api.raafortagro.com/api

# Cloudinary upload widget (optional)
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=raafortagro_unsigned

# Public website URL (for "View website" link)
VITE_SITE_URL=http://localhost:5173
