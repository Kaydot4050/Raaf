# API server
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
# Comma-separated: public site + admin subdomain origins
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Production cookie domain (share session across subdomains)
# COOKIE_DOMAIN=.raafortagro.com

# Link from public site user menu → admin app
VITE_ADMIN_URL=http://localhost:5174
# Optional: this email gets admin role on register
# ADMIN_EMAIL=you@example.com
NODE_ENV=development

# Neon PostgreSQL (database only — not Neon Auth)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Google sign-in / sign-up (Gmail) — use the SAME OAuth client ID in both vars below
# Setup: https://console.cloud.google.com/apis/credentials
#   1. Create project (or pick existing) → APIs & Services → Credentials
#   2. Configure OAuth consent screen (External) → add app name + support email
#   3. Create credentials → OAuth client ID → Application type: Web application
#   4. Authorized JavaScript origins (add every URL users open the site from):
#        http://localhost:5173
#        http://127.0.0.1:5173
#        https://yourdomain.com
#        https://www.yourdomain.com
#   5. Authorized redirect URIs: not required for Google One Tap / GIS button flow
#   6. Copy the Client ID into .env (root) — restart `npm run dev` and `npm run dev:server`
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Twilio SMS for phone login (optional in dev — OTP prints to API console)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1234567890

# Frontend API (optional — defaults to /api via Vite proxy in dev)
# VITE_API_URL=http://localhost:3001/api
# VITE_API_URL=https://api.raafortagro.com/api

# Show "Coming Soon" on production until launch (default: site is public)
# VITE_SITE_LOCKED=true
# VITE_PREVIEW_TOKEN=raafort2026

# Non-blocking coming soon banner on production (set false to hide after launch)
# VITE_COMING_SOON=false

# Cloudinary (optional — admin uploads go to CDN when set)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# CLOUDINARY_FOLDER=raafortagro
# Unsigned upload preset for the admin widget (Settings → Upload → Add upload preset)
# CLOUDINARY_UPLOAD_PRESET=raafortagro_unsigned
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=raafortagro_unsigned
